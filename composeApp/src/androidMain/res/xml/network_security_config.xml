<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext traffic globally for local development with osmdroid -->
    <!-- This allows HTTP tile downloads when HTTPS is not available -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">.</domain>
    </domain-config>
</network-security-config>


